    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/testing": "^11.0.11",
    "@nestjs/throttler": "^6.4.0",
    "@supabase/supabase-js": "^2.86.2",
    "amqplib": "^0.10.4",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
